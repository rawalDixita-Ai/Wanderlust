<%layout("/layouts/boilerplate")-%>

<div class="row justify-content-center">
    <h1 class="col-6">SignUp</h1>
    <div class="col-lg-8 col-md-10">
        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="mb-4">
                <label class="form-label fw-semibold">Username</label>
                <input name="username" class="form-control form-control-lg rounded-3 border-2" type="text" id="username" required/>
                <div class="valid-feedback"></div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Email</label>
                <input name="email" class="form-control form-control-lg rounded-3 border-2" type="text" id="email" required>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Password</label>
                <input name="password" class="form-control form-control-lg rounded-3 border-2" type="text" id="password" required/>
            </div>

            <button class="btn btn-success">SignUp</button>
        </form>
        <p class="mt-3">Already have an account? <a href="/login">Login</a></p>
    </div>
</div>
            