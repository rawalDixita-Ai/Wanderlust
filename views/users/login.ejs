<%layout("/layouts/boilerplate")-%>

<div class="row justify-content-center">
    <h1 class="col-6">Login</h1>
    <div class="col-lg-8 col-md-10">
        <form action="/login" method="POST" class="needs-validation" novalidate>
            <div class="mb-4">
                <label class="form-label fw-semibold">Username</label>
                <input name="username" class="form-control form-control-lg rounded-3 border-2" type="text" id="username" required/>

            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Password</label>
                <input name="password" class="form-control form-control-lg rounded-3 border-2" type="text" id="password" required/>
            </div>

            <button class="btn btn-success">Login</button>
        </form>
    </div>
</div>
            