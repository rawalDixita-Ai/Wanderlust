<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="alert alert-danger col-8 offset-2 col-md-6 offset-md-3" role="alert">
        <h4 class="alert-heading">
            <i class="fa-solid fa-circle-exclamation me-2"></i>
            <%= err.statusCode || 500 %> - Something went wrong
        </h4>
        <hr>
        <p class="mb-0"><%= err.message %></p>
    </div>
    <div class="text-center mt-3">
        <a href="/listings" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to Listings
        </a>
    </div>
</div>
