<%- layout("/layouts/boilerplate") %>
 <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
     integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
     crossorigin=""/>
 <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
     integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
     crossorigin=""></script>

<div class="py-5">
      
      <div class="row justify-content-center">
            <div class="col-10 show-page-content">
                  <h3 class="mb-4">Listing Details:</h3>
                  <img src="<%= listing.image ? listing.image.url : '/default-image.jpg' %>" alt="listing_img" class="show-page-img img-fluid">
                  <h2 class="fw-bold text-center show-page-content" style="color: #E61E4D;"><%=listing.title%></h2>
            </div>
      </div>

      <div class="col-8 offset-2 mt-5 show-page-details">
            
            <ul class="list-unstyled">
                  <li class="mb-2"><i> Owner: <%= listing.owner ? listing.owner.username : "Unknown" %></i></li>
                  <li class="mb-2"><strong>Description:</strong> <%=listing.description%></li>
                  <li class="mb-2"><strong>Price:</strong> &#8377;<%=listing.price.toLocaleString("en-IN")%> / night</li>
                  <li class="mb-2"><strong>Location:</strong> <%=listing.location%>, <%=listing.country%></li>
            </ul>
            <div class="mt-4">
                  <%if(currUser && listing.owner && currUser._id.equals(listing.owner._id)){%>
                  <a class="btn btn-secondary" href="/listings/<%=listing._id%>/edit">Edit listing</a>

                  <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" style="display:inline">
                  <button class="btn btn-danger">Delete this listing</button>
                  </form>
                  <% } %>
            </div>
      </div>

      
      <% if (currUser) { %>
      <hr/>
      <h4>Your Rating</h4>
      <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
        <p class="text-muted mb-2" style="font-size:0.9rem;"></p>
            <div class="rating-group mb-3">
            <fieldset>
            <input type="radio" id="rate5"
           name="review[rating]"
           value="5" />

    <label for="rate5" title="Amazing">
        ⭐⭐⭐⭐⭐
    </label>

    <input type="radio" id="rate4"
           name="review[rating]"
           value="4" />

    <label for="rate4" title="Very good">
      ⭐⭐⭐⭐
        
    </label>

    <input type="radio" id="rate3"
           name="review[rating]"
           value="3" />

    <label for="rate3" title="Average">
      ⭐⭐⭐

       
    </label>

    <input type="radio" id="rate2"
           name="review[rating]"
           value="2" />

    <label for="rate2" title="Poor">
        ⭐⭐
    </label>

    <input type="radio" id="rate1"
           name="review[rating]"
           value="1" required />

    <label for="rate1" title="Terrible">
        ⭐
    </label>
    </fieldset>
    <div class="invalid-feedback">Please select a rating.</div>
    </div>

            <div class="mt-3">
                <textarea name="review[comment]" class="form-control" placeholder="Write your review (at least 3 characters)..." rows="3" required minlength="3" maxlength="500"></textarea>
                <div class="invalid-feedback">Comment must be at least 3 characters.</div>
            </div>
            <div class="mt-2">
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-paper-plane me-1"></i>Submit Review
                </button>
            </div>
      </form>
      <hr/>
      <h4>All Reviews</h4>
      <% if (listing.reviews && listing.reviews.length > 0) { %>
        <% listing.reviews.forEach(function(review) { %>
          <div class="card mb-3 review-card">
            <div class="card-body d-flex justify-content-between align-items-start">
              <div>
                <p class="card-text"><%= review.comment %></p>
                <p class="card-text mb-0">rating: <%= review.rating %>/5</p>
              </div>
              <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="ms-3">
                <button class="btn btn-sm btn-outline-danger delete-review-btn" title="Delete this review">
                  <i class="fa-solid fa-trash-can"></i>
                </button>
              </form>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <p class="text-muted">No reviews yet. Be the first to review!</p>
      <% } %>
      <% } else { %>
      <hr/>
      <p class="text-muted"><a href="/login">Log in</a> to view and add reviews.</p>
      <% } %>

      <hr/>
      <h4>Location</h4>
      <div id="map" style="height: 400px; width: 100%; border-radius: 8px; margin-top: 10px; margin-bottom: 20px;"></div>

    </div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const lat = <%= listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates[1] : 0 %>;
        const lng = <%= listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates[0] : 0 %>;

        const map = L.map("map").setView([lat || 20.5937, lng || 78.9629], lat ? 13 : 5);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        }).addTo(map);

        L.marker([lat || 20.5937, lng || 78.9629])
            .addTo(map)
            .bindPopup("<b><%= listing.title %></b><br/><%= listing.location %>, <%= listing.country %>")
            .openPopup();
    });
</script>
