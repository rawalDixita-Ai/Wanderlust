<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet" 
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" 
      crossorigin="anonymous"/>
    <link rel="stylesheet" href="/style.css"/>
    <link rel="stylesheet" href="/css/chatbot.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer"/>
  </head>

<body>
    <%- include('../includes/navbar.ejs') %>
    <%- include('../includes/flash.ejs') %>
    <div class="container flex-grow-1"><%-body%></div>
    <%-include("../includes/footer.ejs")%>

    <!-- Chatbot Panel -->
    <div class="chatbot-container" style="display: none;">
        <!-- Chat Header -->
        <div class="chat-header">
            <div class="d-flex align-items-center">
                <div class="chatbot-avatar">
                    <i class="fa-solid fa-robot"></i>
                </div>
                <div>
                    <h5 class="mb-0">xyra</h5>
                    <small class="text-light">AI Assistant</small>
                </div>
            </div>
            <button class="btn-close btn-close-white" id="closeChat"></button>
        </div>

        <!-- Chat Messages -->
        <div class="chat-messages" id="chatMessages">
            <div class="message bot-message">
                <div class="message-content">
                    <strong>👋 Welcome!</strong><br><br>
                    I'm your AI travel assistant. I can help you with:<br><br>
                    <div class="feature-buttons">
                        <button class="feature-btn" data-feature="trip">
                            <i class="fa-solid fa-map-location-dot"></i><br>
                            <strong>Trip Planner</strong><br>
                            <small>Design your itinerary</small>
                        </button>
                        <button class="feature-btn" data-feature="review">
                            <i class="fa-solid fa-star"></i><br>
                            <strong>Review Summary</strong><br>
                            <small>Summarize reviews</small>
                        </button>
                        <button class="feature-btn" data-feature="price">
                            <i class="fa-solid fa-indian-rupee-sign"></i><br>
                            <strong>Price Insights</strong><br>
                            <small>Smart pricing tips</small>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions" id="quickActions">
            <button class="quick-action-btn" data-message="Plan a 3-day trip">
                <i class="fa-solid fa-calendar-days"></i> Plan Trip
            </button>
            <button class="quick-action-btn" data-message="Summarize reviews">
                <i class="fa-solid fa-file-lines"></i> Reviews
            </button>
            <button class="quick-action-btn" data-message="Is this price fair?">
                <i class="fa-solid fa-tag"></i> Price Check
            </button>
        </div>

        <!-- Chat Input -->
        <div class="chat-input">
            <form id="chatForm">
                <div class="input-group">
                    <input 
                        type="text" 
                        class="form-control" 
                        id="messageInput" 
                        placeholder="Type your message..." 
                        autocomplete="off"
                        required
                    >
                    <button class="btn btn-send" type="submit">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="/js/chatbot.js"></script>
    <script src="/js/script.js"></script>
  </body>
</html>
